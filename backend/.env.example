# Backend environment variables — copy to .env and fill in values

# API key for /analyze-custom endpoint (leave as default for local dev)
API_KEY=dev-key-optional

# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Deployment context (local|staging|production)
DEPLOYMENT_ENV=local

# FinBERT confidence threshold for aggregation (default 0.55 = filter low-confidence neutrals)
FINBERT_MIN_CONFIDENCE=0.55
