frontend/**/amplify/.config/local-*
frontend/**/amplify/logs/
frontend/**/amplify/mock-data/
frontend/**/amplify/mock-api-resources/
frontend/**/amplify/backend/amplify-meta.json
frontend/**/amplify/backend/.temp/
aws-exports.js
awsconfiguration.json
amplifyconfiguration.json

